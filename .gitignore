# --- SECRETS & CREDENTIALS ---
# This is the most important line!
.env
*.env
secrets.py
credentials.json

# --- PYTHON ---
# Ignore compiled code and cache
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# --- VIRTUAL ENVIRONMENTS ---
# These are huge folders you don't need to upload
venv/
.venv/
env/
ENV/

# --- DATABASE (MySQL) ---
# Ignore local database dumps or logs
*.sql
*.log
mysql-data/

# --- OS SPECIFIC ---
.DS_Store
Thumbs.db